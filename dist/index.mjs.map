{
  "name": "moodenglink",
  "version": "1.7.0",
  "description": "A powerful, modern Lavalink v4 client for Node.js — inspired by Sonatica, Magmastream, Moonlink.js and Erela.js.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:tsc": "tsc",
    "dev": "tsup --watch",
    "lint": "prettier --check \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "lavalink",
    "lavalink-client",
    "discord",
    "music",
    "moodeng",
    "moodenglink",
    "audio",
    "player",
    "v4"
  ],
  "author": "Moodeng Lab",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Moodeng-LAB/moodenglink.git"
  },
  "bugs": {
    "url": "https://github.com/Moodeng-LAB/moodenglink/issues"
  },
  "homepage": "https://github.com/Moodeng-LAB/moodenglink#readme",
  "dependencies": {
    "@discordjs/collection": "^2.1.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^4.1.10",
    "prettier": "^3.3.3",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
